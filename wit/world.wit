package ur:extension@0.2.0;

/// Shared types used across all interfaces.
interface types {
    /// A tool call requested by the LLM.
    record tool-call {
        id: string,
        name: string,
        arguments-json: string,
        /// Opaque provider-specific metadata to echo back on the next request.
        provider-metadata-json: string,
    }

    /// The result of a tool invocation, linked back to the original call.
    record tool-result {
        tool-call-id: string,
        tool-name: string,
        content: string,
    }

    /// A single part of a message — text, tool call, or tool result.
    variant message-part {
        text(string),
        tool-call(tool-call),
        tool-result(tool-result),
    }

    /// A single message in a conversation.
    record message {
        role: string,
        parts: list<message-part>,
    }

    /// Token usage statistics.
    record usage {
        input-tokens: u32,
        output-tokens: u32,
    }

    /// The result of a completion request.
    record completion {
        message: message,
        usage: option<usage>,
    }

    /// Summary information about a session.
    record session-info {
        id: string,
        title: option<string>,
    }

    /// A key-value configuration entry.
    record config-entry {
        key: string,
        value: string,
    }

    /// Schema for an integer setting with bounds and default.
    record setting-integer {
        min: s64,
        max: s64,
        default-val: s64,
    }

    /// Schema for an enumeration setting with allowed values and default.
    record setting-enum {
        allowed: list<string>,
        default-val: string,
    }

    /// Schema for a boolean setting with default.
    record setting-boolean {
        default-val: bool,
    }

    /// Typed schema describing what values a setting accepts.
    variant setting-schema {
        integer(setting-integer),
        enumeration(setting-enum),
        boolean(setting-boolean),
    }

    /// Describes a single configurable setting for a model.
    record setting-descriptor {
        key: string,
        name: string,
        description: string,
        schema: setting-schema,
    }

    /// Describes a model offered by an LLM provider.
    record model-descriptor {
        id: string,
        name: string,
        description: string,
        is-default: bool,
        settings: list<setting-descriptor>,
        context-window-in: u32,
        context-window-out: u32,
        knowledge-cutoff: string,
        cost-in: u32,
        cost-out: u32,
    }

    /// A typed setting value.
    variant setting-value {
        integer(s64),
        enumeration(string),
        boolean(bool),
    }

    /// A key-value pair with a typed value, for passing settings to providers.
    record config-setting {
        key: string,
        value: setting-value,
    }

    /// Describes a tool that an extension can handle.
    record tool-descriptor {
        name: string,
        description: string,
        parameters-json-schema: string,
    }

    /// A single chunk from a streaming completion.
    record completion-chunk {
        delta-parts: list<message-part>,
        finish-reason: option<string>,
        usage: option<usage>,
    }
}

/// Platform capabilities imported by all extensions.
///
/// Extensions call `host.*` for platform services. The host routes
/// each call to the active provider for the corresponding slot.
interface host {
    use types.{message, completion, session-info, config-entry};

    /// Emit a log message to the host.
    log: func(msg: string);

    /// Request a completion from the active LLM provider.
    ///
    /// `role` selects which model mapping to use (e.g. "fast").
    /// `None` resolves to the "default" role.
    complete: func(messages: list<message>, role: option<string>) -> result<completion, string>;

    /// Load all messages for a session.
    load-session: func(id: string) -> result<list<message>, string>;

    /// Append a message to a session.
    append-session: func(id: string, msg: message) -> result<_, string>;

    /// List available sessions.
    list-sessions: func() -> result<list<session-info>, string>;

    /// Compact a message history.
    compact: func(messages: list<message>) -> result<list<message>, string>;
}

/// Common extension lifecycle and generic tool support.
interface extension {
    use types.{config-entry, tool-descriptor};

    /// Initialize the extension with configuration.
    init: func(config: list<config-entry>) -> result<_, string>;

    /// Call a named tool with JSON arguments.
    call-tool: func(name: string, args-json: string) -> result<string, string>;

    /// The extension's unique identifier.
    id: func() -> string;

    /// The extension's human-readable name.
    name: func() -> string;

    /// Declare the tools this extension can handle.
    list-tools: func() -> list<tool-descriptor>;
}

/// Exported by extensions filling the `llm-provider` slot.
interface llm-provider {
    use types.{message, completion, model-descriptor, config-setting, tool-descriptor};

    /// The provider's short identifier (e.g. "anthropic", "openai").
    ///
    /// Used as the prefix in model references like "anthropic/claude-sonnet-4".
    provider-id: func() -> string;

    /// Declare available models and their settings schemas.
    list-models: func() -> list<model-descriptor>;

    /// Perform a completion with a resolved model and typed settings.
    complete: func(messages: list<message>, model: string, settings: list<config-setting>,
                   tools: list<tool-descriptor>) -> result<completion, string>;
}

/// Exported by extensions filling the `llm-provider` slot (streaming).
interface llm-streaming-provider {
    use types.{message, config-setting, completion-chunk, tool-descriptor};

    /// A stream of completion chunks pulled incrementally.
    resource completion-stream {
        /// Returns the next chunk, or `none` when the stream is exhausted.
        next: func() -> option<completion-chunk>;
    }

    /// Begin a streaming completion. The caller pulls chunks via the
    /// returned resource handle.
    complete-streaming: func(messages: list<message>, model: string,
                             settings: list<config-setting>,
                             tools: list<tool-descriptor>)
        -> result<completion-stream, string>;
}

/// Exported by extensions filling the `session-provider` slot.
interface session-provider {
    use types.{message, session-info};

    /// Load all messages for a session.
    load: func(id: string) -> result<list<message>, string>;

    /// Append a message to a session.
    append: func(id: string, msg: message) -> result<_, string>;

    /// List available sessions.
    list-sessions: func() -> result<list<session-info>, string>;
}

/// Exported by extensions filling the `compaction-provider` slot.
interface compaction-provider {
    use types.{message};

    /// Compact a message history into fewer messages.
    compact: func(messages: list<message>) -> result<list<message>, string>;
}

// -- Worlds ---------------------------------------------------------------

/// World for extensions that provide LLM completions (host-side bindings).
world llm-extension {
    import host;
    export extension;
    export llm-provider;
    export llm-streaming-provider;
}

/// World for LLM extensions that make outbound HTTP requests (guest-side).
world llm-extension-http {
    import host;
    import wasi:http/outgoing-handler@0.2.6;
    export extension;
    export llm-provider;
    export llm-streaming-provider;
}

/// World for extensions that provide session persistence.
world session-extension {
    import host;
    export extension;
    export session-provider;
}

/// World for extensions that provide compaction.
world compaction-extension {
    import host;
    export extension;
    export compaction-provider;
}

/// World for general-purpose extensions with no slot.
world general-extension {
    import host;
    export extension;
}
